<!-- Position Probe -->
<m-position-probe range="3.0" id="probe"></m-position-probe>

<script>
// ── Config ────────────────────────────────────────────────────────────────
const SNES_SERVER_WS = "wss://snes-server-production.up.railway.app/tunnel";
const BACKEND_SERVER = "https://gamer-production.up.railway.app";
const ROM_ID = "kaizo-mario-world-1";

// Wallet passed via MML world context if available, fallback anonymous
const WALLET = (typeof mmlWorld !== "undefined" && mmlWorld.wallet)
? mmlWorld.wallet
: "anonymous";

// ── Elements ──────────────────────────────────────────────────────────────
const screen = document.getElementById("screen");
const audio = document.getElementById("audio");
const probe = document.getElementById("probe");
const card = document.getElementById("info-card");
const compLabel = document.getElementById("completion-label");
const interaction = document.getElementById("play-btn");

// ── WebSocket State ───────────────────────────────────────────────────────
let socket = null;
let gameActive = false;

// ── Gameboy Blueprint Pattern ─────────────────────────────────────────────
// Server sends { image: "data:image/png;base64,...", audio: "..." } each frame
// We update m-image src and m-audio src exactly as the GB blueprint does
function connectToSNESServer() {
socket = new WebSocket(SNES_SERVER_WS + "?rom=" + ROM_ID + "&wallet=" + WALLET);

socket.onopen = () => {
console.log("SNES stream connected");
gameActive = true;
interaction.setAttribute("prompt", "Press E to Close Game");
};

socket.onmessage = (msg) => {
const frame = JSON.parse(msg.data);

// Update screen — same as Gameboy blueprint line 17
if (frame.image) {
screen.setAttribute("src", frame.image);
}

// Update audio — same as Gameboy blueprint lines 18-20
if (frame.audio) {
audio.setAttribute("src", frame.audio);
audio.setAttribute("enabled", "true");
audio.setAttribute("start-time", document.timeline.currentTime);
}

// Completion signal from server
if (frame.type === "completion") {
logCompletion();
}
};

socket.onclose = () => {
console.log("SNES stream closed");
gameActive = false;
// Restore preview image
screen.setAttribute("src", "https://jdunk4.github.io/Gamer/SMW%20-%20Kaizo%20Mario%20World%201.png");
audio.setAttribute("enabled", "false");
interaction.setAttribute("prompt", "Press E to Play Kaizo Mario World");
};

socket.onerror = (e) => {
console.error("WebSocket error:", e);
socket.close();
};
}

// ── Input — sendKey mirrors Gameboy blueprint exactly ─────────────────────
// keyDown + keyUp after 200ms, same timing as the GB blueprint
function sendKey(key) {
if (!socket || socket.readyState !== WebSocket.OPEN) return;
socket.send(JSON.stringify({ type: "keyDown", key }));
setTimeout(() => {
socket.send(JSON.stringify({ type: "keyUp", key }));
}, 200);
}

// ── Keyboard mapping ──────────────────────────────────────────────────────
// Maps physical keyboard keys to SNES buttons sent to server
// Player uses keyboard while standing at the cabinet in-world
document.addEventListener("keydown", (e) => {
if (!gameActive) return;
const map = {
ArrowUp: "up",
ArrowDown: "down",
ArrowLeft: "left",
ArrowRight: "right",
z: "a", // SNES A
x: "b", // SNES B
a: "x", // SNES X
s: "y", // SNES Y
Enter: "start",
Shift: "select"
};
if (map[e.key]) sendKey(map[e.key]);
});

// ── Game toggle ───────────────────────────────────────────────────────────
function launchGame() {
if (socket && socket.readyState === WebSocket.OPEN) return;
connectToSNESServer();
}

function closeGame() {
if (socket) socket.close();
}

// ── Proximity ─────────────────────────────────────────────────────────────
probe.addEventListener("positionenter", () => {
card.setAttribute("visible", "true");
});
probe.addEventListener("positionleave", () => {
card.setAttribute("visible", "false");
if (gameActive) closeGame();
});

// ── Completion logging ────────────────────────────────────────────────────
async function logCompletion() {
try {
await fetch(BACKEND_SERVER + "/complete", {
method: "POST",
headers: { "Content-Type": "application/json" },
body: JSON.stringify({ wallet: WALLET, rom: ROM_ID })
});
refreshCompletionCount();
} catch (e) {}
}

async function refreshCompletionCount() {
try {
const res = await fetch(BACKEND_SERVER + "/completions/" + ROM_ID);
const data = await res.json();
const count = data.count || 0;
compLabel.setAttribute(
"content",
count + " player" + (count !== 1 ? "s" : "") + " completed"
);
} catch (e) {}
}

refreshCompletionCount();
</script>

<!-- Interaction: toggle stream on/off -->
<m-interaction
id="play-btn"
prompt="Press E to Play Kaizo Mario World"
range="2.5"
oninteract="gameActive ? closeGame() : launchGame()">
</m-interaction>

</m-group>
